{
  "name": "epiuse-app",
  "version": "1.0.0",
  "description": "Employee hierarchy management system for EPI-USE Africa",
  "main": "server/src/index.js",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "start": "NODE_ENV=production node server/src/index.js",
    "seed": "node server/scripts/seed-tech-company.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sparta379/employee-hierarchy-v3.git"
  },
  "author": "Dandre Vermaak",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10"
  }
}
